# Copy to .env and fill in. NEVER commit .env. (Guide §5, Appendix A)

# ---- core ----
NODE_ENV=development
API_PORT=4000
APP_URL=http://shopnova.localtest.me:3000
LOG_LEVEL=debug

# ---- database (docker-compose defaults) ----
DATABASE_URL=postgresql://aq:aq@localhost:5432/astronomiq?schema=public
DIRECT_URL=postgresql://aq:aq@localhost:5432/astronomiq?schema=public

# ---- redis ----
REDIS_URL=redis://localhost:6379

# ---- auth (keycloak, docker-compose defaults) ----
OIDC_ISSUER=http://localhost:8080/realms/astronomiq
OIDC_CLIENT_ID=aq-api
OIDC_CLIENT_SECRET=dev-secret-change-me
JWT_SECRET=dev-jwt-secret-at-least-32-bytes-long!!

# ---- storage (unused until Phase D/E; use MinIO or real S3 later) ----
AWS_REGION=ap-south-1
S3_BUCKET=astronomiq-media-dev

# ---- whatsapp (Phase D — Meta Cloud API test number) ----
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_VERIFY_TOKEN=aq-verify-dev
WA_APP_SECRET=

# ---- telephony (Phase F — Exotel sandbox) ----
EXOTEL_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SUBDOMAIN=api.exotel.com

# ---- AI (Phase C) ----
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-5
EMBEDDINGS_MODEL=voyage-3

# ---- STT/TTS (Phase F) ----
SARVAM_API_KEY=
ELEVENLABS_API_KEY=
